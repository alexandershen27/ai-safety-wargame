# Local dev: leave these unset and the app writes to ./wargame.db.
# Production (Vercel + Turso): set both. Get them from `turso db show <name>`
# and `turso db tokens create <name>` after creating your Turso DB.

# DATABASE_URL=libsql://your-db-name-yourname.turso.io
# DATABASE_AUTH_TOKEN=ey...your-jwt...
